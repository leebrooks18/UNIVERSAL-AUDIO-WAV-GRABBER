{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 10,
      "regions": ["iad1"]
    }
  },
  "rewrites": [
    { "source": "/api/:match*", "destination": "/api/:match*" }
  ],
  "headers": [
    {
      "source": "(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer-when-downgrade" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://unpkg.com; connect-src 'self' https://accounts.spotify.com https://api.spotify.com; img-src 'self' data:; object-src 'none'; frame-ancestors 'none';" }
      ]
    }
  ],
  "cleanUrls": true
}
